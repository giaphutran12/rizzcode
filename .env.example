# Server-only secrets. Never expose these through VITE_* variables,
# client bundles, rendered HTML, network responses, or logs.

# OpenAI API key used by the server-side judge endpoint (required for judging).
OPENAI_API_KEY=

# Optional judge model override. Defaults to gpt-5.4 when unset.
RIZZCODE_JUDGE_MODEL=

# Test-only: when "1", the dev server answers /api/judge with a deterministic
# mock so browser tests never call a real provider. Never set in production.
RIZZCODE_JUDGE_MOCK=
